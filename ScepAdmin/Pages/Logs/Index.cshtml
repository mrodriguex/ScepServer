@page
@model ScepAdmin.Pages.Logs.IndexModel
@{
    ViewData["Title"] = "Issuance Logs";
}

<h2 class="mb-4"><i class="bi bi-journal-text"></i> Issuance Logs</h2>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-sm mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Timestamp</th>
                    <th>Operation</th>
                    <th>Status</th>
                    <th>Device ID</th>
                    <th>Client IP</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Logs.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No logs found.</td></tr>
                }
                @foreach (var log in Model.Logs)
                {
                    string statusClass = log.Status == "Success" ? "bg-success" : "bg-danger";
                    <tr>
                        <td><small>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</small></td>
                        <td><span class="badge bg-secondary">@log.Operation</span></td>
                        <td><span class="badge @statusClass">@log.Status</span></td>
                        <td>@(log.DeviceId.HasValue ? log.DeviceId.ToString() : "-")</td>
                        <td><code>@log.ClientIp</code></td>
                        <td><small>@log.Message</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
